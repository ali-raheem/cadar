import Text_IO;
use Text_IO;
import Flow;

package Flow {
    fn Add(Integer A, Integer B) -> Integer
        global(null)
        depends(result => [A, B]);

    fn Show(Integer Value)
        global(null)
        depends(null => Value);
}

package body Flow {
    fn Add(Integer A, Integer B) -> Integer {
        return A + B;
    }

    fn Show(Integer Value) {
        Put_Line(Integer.image(Value));
    }
}

fn Main() {
    Flow.Show(Flow.Add(2, 3));
}
